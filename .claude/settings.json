{
  "permissions": {
    "allow": [
      "WebFetch(domain:stackoverflow.com)",
      "Bash(git restore *)"
    ],
    "deny": [
      "Read(/)",
      "Read(/Users/*)",
      "Read(C:\\Users\\*)",
      "Read(/home/*)",
      "Write(/)",
      "Write(/Users/*)",
      "Write(C:\\Users\\*)",
      "Write(/home/*)",
      "Edit(/)",
      "Edit(/Users/*)",
      "Edit(C:\\Users\\*)",
      "Edit(/home/*)",
      "Bash(*)"
    ]
  },
  "remoteControlAtStartup": true
}
